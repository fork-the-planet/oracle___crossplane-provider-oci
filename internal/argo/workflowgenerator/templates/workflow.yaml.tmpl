apiVersion: argoproj.io/v1alpha1
kind: Workflow
metadata:
  generateName: oci-crossplane-test-
spec:
  serviceAccountName: argo-workflow
  entrypoint: crossplane-provider-oci-test-workflow
  volumes:
    - name: git-repo
      persistentVolumeClaim:
        claimName: git-repo-pvc
  arguments:
    parameters:
    {{- range .Services }}
    - name: {{ .RunParam }}
      value: "false"
    {{- end }}
    {{- range .Parameters }}
    - name: {{ .Name }}
      value: "{{ .Value }}"
    {{- end }}
  templates:
    - name: crossplane-provider-oci-test-workflow
      dag:
        tasks:
        {{- range .Services }}
        - name: {{ .TaskName }}
          templateRef:
            name: {{ .Name }}
            template: {{ .Entrypoint }}
          when: "{{ resolveWhen .RunParam }}"
          {{- if .Namespaced }}
          withParam: "{{ resolveParameter $.NamespaceListParam }}"
          {{- end }}
          arguments:
            parameters:
            {{- if .Namespaced }}
              - name: {{ .NamespaceParameter }}
                value: "{{"{{"}}item{{"}}"}}"
            {{- end }}
            {{- range .Parameters }}
              {{- if ne .Name "target_namespace" }}
              - name: {{ .Name }}
                value: "{{ resolveParameter .Name }}"
              {{- end }}
            {{- end }}
        {{- end }}
